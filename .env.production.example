# =============================================================================
# CVD 实验数据采集系统 — 生产部署环境变量模板
# 使用方法：
#   1. cp .env.production.example .env
#   2. 修改所有 change-me-* 和 YOUR_* 占位符
#   3. 部署: ./deploy.sh
# =============================================================================

# --- 应用配置 ---
APP_NAME=CVD Backend
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000

# --- 数据库（Docker Compose 自动从 POSTGRES_* 构建） ---
POSTGRES_DB=cvd
POSTGRES_USER=postgres
# 用以下命令生成强密码：openssl rand -base64 24
POSTGRES_PASSWORD=YOUR_STRONG_POSTGRES_PASSWORD
POSTGRES_PORT=5432

# --- JWT 密钥（必须生成唯一随机值） ---
# 生成命令：openssl rand -hex 32
JWT_SECRET_KEY=YOUR_RANDOM_JWT_SECRET_OPENSSL_RAND_HEX_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- 内部注册邀请码 ---
# 用户自助注册时必须输入该值；未配置时注册接口会拒绝请求。
REGISTRATION_INVITE_CODE=YOUR_INTERNAL_REGISTRATION_INVITE_CODE

# --- 文件上传 ---
FILE_UPLOAD_MAX_BYTES=52428800
# Docker Compose 内部存储路径，不需要改
COMPOSE_FILE_STORAGE_ROOT=/data/storage

# --- CORS 允许来源 ---
# Docker Compose 部署时前端和后端通过 nginx 同源访问，通常不需要额外配置。
# 如果后端直接暴露端口对外服务，请添加服务器 IP/主机名：
# CORS_ALLOW_ORIGINS=http://your-server-ip:5173,http://your-server-hostname:5173
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- 前端配置 ---
# Docker Compose 默认通过 nginx 同源 /api 代理，设为 / 即可
VITE_API_BASE_URL=/
# 对外访问端口（默认 80）
FRONTEND_PORT=80
BACKEND_PORT=8000

# =============================================================================
# 部署后还需手动执行：
#   docker compose exec backend uv run python -m app.commands.create_admin
# =============================================================================
