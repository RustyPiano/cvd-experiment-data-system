APP_NAME=CVD Backend
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/cvd
FILE_STORAGE_ROOT=./storage
FILE_UPLOAD_MAX_BYTES=52428800
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173
# Do not use this JWT secret in production.
JWT_SECRET_KEY=change-me-before-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Docker Compose defaults
POSTGRES_DB=cvd
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
BACKEND_PORT=8000
FRONTEND_PORT=5173
COMPOSE_DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/cvd
COMPOSE_FILE_STORAGE_ROOT=/data/storage
# Docker Compose defaults to same-origin /api proxying through nginx.
# Set a full URL only if frontend and backend are deployed on different origins.
VITE_API_BASE_URL=/
