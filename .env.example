# =============================================================================
# CVD 实验数据采集系统 — 本地开发环境变量（仅用于本地开发，不要用于部署）
# =============================================================================
# 部署到服务器请使用 .env.production.example 模板
# =============================================================================

APP_NAME=CVD Backend
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=postgresql+psycopg://postgres:change-me-local-postgres@localhost:5432/cvd
FILE_STORAGE_ROOT=./storage
FILE_UPLOAD_MAX_BYTES=52428800
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173
# 生成方式: openssl rand -hex 32
JWT_SECRET_KEY=change-me-generate-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
# 内部账号注册邀请码；未配置时注册接口会拒绝请求
REGISTRATION_INVITE_CODE=change-me-local-invite-code

# Docker Compose 默认值
POSTGRES_DB=cvd
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-local-postgres
POSTGRES_PORT=5432
BACKEND_PORT=8000
FRONTEND_PORT=5173
# 可选覆写。docker-compose.yml 默认从 POSTGRES_* 自动构建。
# COMPOSE_DATABASE_URL=postgresql+psycopg://postgres:change-me-local-postgres@postgres:5432/cvd
COMPOSE_FILE_STORAGE_ROOT=/data/storage
# Docker Compose 默认通过 nginx 同源 /api 代理访问后端。
# 仅当前端和后端不在同一 origin 时才设为完整 URL。
VITE_API_BASE_URL=/
